{
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "[ -n \"$TMUX_PANE\" ] && tmux set -w -t \"$TMUX_PANE\" @claude waiting 2>/dev/null || true" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "[ -n \"$TMUX_PANE\" ] && tmux set -w -t \"$TMUX_PANE\" @claude busy 2>/dev/null || true" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "[ -n \"$TMUX_PANE\" ] || exit 0; n=$(jq -r '(.background_tasks | length) // 0' 2>/dev/null); case \"$n\" in ''|*[!0-9]*) n=0;; esac; [ \"$n\" -gt 0 ] && s=busy || s=idle; tmux set -w -t \"$TMUX_PANE\" @claude \"$s\" 2>/dev/null || true" }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/steven/.claude/statusline-command.sh"
  },
  "enabledPlugins": {},
  "alwaysThinkingEnabled": true,
  "tui": "default",
  "autoMemoryDirectory": "~/.claude/shared-memory",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
